{
  // Standart loglama seviyelerini belirliyoruz.
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  // Tum baglantilara izin veriyoruz.
  "AllowedHosts": "*",
  // YARP ana motor yapilandirmasi.
  "ReverseProxy": {
    "Routes": {
      "PaymentRoute": {
        // Hedef kume baglantisi.
        "ClusterId": "PaymentCluster",
        "Match": {
          // Yakalanacak rotayi belirliyoruz.
          "Path": "/api/payments/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "PaymentCluster": {
        "Destinations": {
          // Sadece tek bir gercek hedefimiz var, Polly ayni hedefe tekrar vuracak.
          "destination1": {
            "Address": "https://localhost:5001"
          }
        },
        // Kestrel'in HTTP/2 el sikisma krizini onlemek icin HTTP/1.1 kullaniyoruz.
        "HttpRequest": {
          "Version": "1.1",
          "VersionPolicy": "RequestVersionExact"
        },
        // Arka plana giderken mTLS sertifikamizi kullaniyoruz.
        "HttpClient": {
          "DangerousAcceptAnyServerCertificate": true,
          "ClientCertificate": {
            "Path": "client.pfx",
            "Password": "root123"
          }
        }
      }
    }
  }
}
