{
  // Standart loglama seviyeleri.
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  // Kestrel (ASP.NET Core'un gomulu web sunucusu) ayarlarini tanimliyoruz.
  "Kestrel": {
    "Endpoints": {
      // Sadece HTTPS uzerinden ve 5001 portundan gelen istekleri dinleyecegiz.
      "Https": {
        "Url": "https://localhost:5001"
      }
    }
  },
  "AllowedHosts": "*"
}
